{
  "name": "@stance-dev/core",
  "version": "0.0.0",
  "description": "An opinionated, accessible, themeable Vue 3 component library, built for Tailwind consumers without specificity fights.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orihay23/stance.git",
    "directory": "packages/core"
  },
  "homepage": "https://orihay23.github.io/stance/",
  "bugs": "https://github.com/orihay23/stance/issues",
  "keywords": ["vue", "vue3", "component-library", "tailwind", "tailwindcss", "accessibility", "a11y", "design-system"],
  "main": "./dist/stance-core.js",
  "module": "./dist/stance-core.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/stance-core.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "sideEffects": ["dist/style.css"],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "pretest": "pnpm --filter @stance-dev/themes build",
    "test": "vitest run",
    "pretest:watch": "pnpm --filter @stance-dev/themes build",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@floating-ui/vue": "^2.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@stance-dev/themes": "workspace:*",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "axe-core": "^4.10.2",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}
