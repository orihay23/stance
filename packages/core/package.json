{
  "name": "@stance/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/stance-core.js",
  "module": "./dist/stance-core.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/stance-core.js"
