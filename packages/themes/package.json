{
  "name": "@stance/themes",
  "version": "0.0.0",
  "description": "Palette and density theme compilers for @stance/core — compiles ColorPalette/DensityProfile token objects to CSS custom properties.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orihay23/stance.git",
    "directory": "packages/themes"
  },
  "homepage": "https://orihay23.github.io/stance/",
  "bugs": "https://github.com/orihay23/stance/issues",
  "keywords": ["theme", "design-tokens", "css-custom-properties", "stance"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
