strict-peer-dependencies=true
auto-install-peers=false
save-workspace-protocol=true

# Read by pnpm publish in the release workflow (.github/workflows/ci.yml's
# `release` job) — pnpm doesn't auto-consume the plain NPM_TOKEN/
# NODE_AUTH_TOKEN env vars actions/setup-node wires up for npm the way
# npm/yarn do; it needs the registry auth line spelled out explicitly.
# Interpolates ${NPM_TOKEN} from the environment at publish time — no
# secret value lives in this file.
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
